{
  "name": "vetoreco-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-01",
  "vars": {
    "APP_ORIGIN": "https://vetoreco.pages.dev",
    "SESSION_DAYS": "14",
    "COOKIE_SECURE": "true"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vetoreco",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
    }
  ]
}
