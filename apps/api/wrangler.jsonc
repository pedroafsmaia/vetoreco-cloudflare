{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vetoreco-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-25",
  "vars": {
    "APP_ORIGIN": "http://localhost:5173"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vetoreco",
      "database_id": "CHANGE-ME"
    }
  ]
}
